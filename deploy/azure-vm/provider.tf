terraform {
  required_version = ">= 1.0"

  required_providers {
    azurerm = {
      source  = "hashicorp/azurerm"
      version = "~> 3.0"
    }
  }
}

provider "azurerm" {
  features {}
  # Skip auto-registering resource providers (requires subscription Owner/Contributor).
  skip_provider_registration = true
}
