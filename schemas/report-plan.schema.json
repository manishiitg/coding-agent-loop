        "id": {
          "type": "string"
        },
        "heading": {
          "type": "string"
        },
        "entries": {
          "items": {
            "$ref": "#/$defs/reportPlanDocumentEntry"
          },
          "type": "array"
        },
        "layout": {
          "$ref": "#/$defs/reportPlanDocumentSectionLayout"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "heading"
      ]
