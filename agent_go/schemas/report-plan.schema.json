{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "reportPlanDocumentEntry": {
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "single",
            "row"
          ]
        },
        "tab": {
          "type": "string"
        },
        "widget": {
          "$ref": "#/$defs/reportPlanDocumentWidget"
        },
        "row": {
          "$ref": "#/$defs/reportPlanDocumentRow"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "kind"
      ]
    },
    "reportPlanDocumentInteractionOption": {
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "id",
        "title"
      ]
    },
    "reportPlanDocumentRow": {
      "properties": {
        "widgets": {
          "items": {
            "$ref": "#/$defs/reportPlanDocumentWidget"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "widgets"
      ]
    },
    "reportPlanDocumentSection": {
      "properties": {
        "id": {
          "type": "string"
        },
        "heading": {
          "type": "string"
        },
        "entries": {
          "items": {
            "$ref": "#/$defs/reportPlanDocumentEntry"
          },
          "type": "array"
        },
        "layout": {
          "$ref": "#/$defs/reportPlanDocumentSectionLayout"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "heading"
      ]
    },
    "reportPlanDocumentSectionLayout": {
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "grid",
            "tabs"
          ]
        },
        "columns": {
          "type": "integer"
        },
        "gap": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "reportPlanDocumentThemeColors": {
      "properties": {
        "primary": {
          "type": "string"
        },
        "accent": {
          "type": "string"
        },
        "card": {
          "type": "string"
        },
        "muted": {
          "type": "string"
        },
        "border": {
          "type": "string"
        },
        "chart": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "reportPlanDocumentWidget": {
      "properties": {
        "id": {
          "type": "string"
        },
        "hidden": {
          "type": "boolean"
        },
        "kind": {
          "type": "string",
          "enum": [
            "file",
            "file-list",
            "interaction"
          ]
        },
        "source": {
          "type": "string"
        },
        "db": {
          "type": "string"
        },
        "sql": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "filter": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "height": {
          "type": "integer"
        },
        "showIf": {
          "type": "string"
        },
        "renderFormat": {
          "type": "string",
          "enum": [
            "auto",
            "html",
            "text",
            "code",
            "json",
            "image",
            "video",
            "audio",
            "pdf",
            "link"
          ]
        },
        "listFormat": {
          "type": "string",
          "enum": [
            "list",
            "cards",
            "table",
            "gallery"
          ]
        },
        "recursive": {
          "type": "boolean"
        },
        "extensions": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "maxItems": {
          "type": "integer"
        },
        "question": {
          "type": "string"
        },
        "responseKind": {
          "type": "string",
          "enum": [
            "choice",
            "text",
            "choice-with-text"
          ]
        },
        "options": {
          "items": {
            "$ref": "#/$defs/reportPlanDocumentInteractionOption"
          },
          "type": "array"
        },
        "allowFreeText": {
          "type": "boolean"
        },
        "placeholder": {
          "type": "string"
        },
        "instanceKey": {
          "type": "string"
        },
        "subjectId": {
          "type": "string"
        },
        "subjectVersion": {
          "type": "string"
        },
        "subjectHash": {
          "type": "string"
        },
        "layout": {
          "$ref": "#/$defs/reportPlanDocumentWidgetLayout"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "kind"
      ]
    },
    "reportPlanDocumentWidgetLayout": {
      "properties": {
        "span": {
          "type": "integer"
        },
        "minWidth": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object"
    }
  },
  "properties": {
    "version": {
      "type": "integer"
    },
    "theme": {
      "type": "string"
    },
    "themeColors": {
      "$ref": "#/$defs/reportPlanDocumentThemeColors"
    },
    "sections": {
      "items": {
        "$ref": "#/$defs/reportPlanDocumentSection"
      },
      "type": "array"
    }
  },
  "additionalProperties": false,
  "type": "object"
}
