# === Required ===
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_PRIMARY_MODEL=claude-sonnet-4-5

# === Database ===
# SQLite (default, no external DB needed):
DB_TYPE=sqlite
# Postgres (optional):
# DB_TYPE=postgres
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# === LLM Providers ===
LLM_CONFIG_LOCKED=false
SUPPORTED_LLM_PROVIDERS=anthropic

# Optional: Azure AI
# AZURE_AI_API_KEY=
# AZURE_AI_ENDPOINT=
# SUPPORTED_LLM_PROVIDERS=anthropic,azure

# === Published Models (shown in UI) ===
DEFAULT_PUBLISHED_LLMS='[{"id":"anthropic-sonnet-4-5","name":"Claude Sonnet 4.5","provider":"anthropic","model_id":"claude-sonnet-4-5"},{"id":"anthropic-haiku-4-5","name":"Claude Haiku 4.5","provider":"anthropic","model_id":"claude-haiku-4-5"}]'

# === Optional: Tracing ===
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://us.cloud.langfuse.com
# TRACING_PROVIDER=langfuse

# === Optional: Agent config ===
MAX_TURNS=500

# === Optional: Global secrets (injected into agent queries) ===
# GLOBAL_SECRET_GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...
