# Copy to terraform.tfvars and fill in (do not commit terraform.tfvars).

resource_group_name = "code-analysis-phase-1"
location            = "eastus"
project_name        = "mcpagent"
dns_label           = "mcpagent"   # Results in mcpagent.eastus.cloudapp.azure.com

# VM config
# vm_size             = "Standard_B2ms"   # 2 vCPU / 8 GB RAM (default)
# admin_username      = "azureuser"
# ssh_public_key_path = "~/.ssh/id_rsa.pub"
# data_disk_size_gb   = 32

# Optional: expose agent (8000) and workspace-api (8080) ports for debugging
# expose_backend_ports = true

# Optional: API keys and env (use TF_VAR_* or a secret backend; do not commit)
# openai_api_key = ""
# agent_env = {}
# workspace_api_env = {}
