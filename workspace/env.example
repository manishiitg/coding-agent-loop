# GitHub Configuration
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=city-mall/mcp-agent-docs

# Server Configuration
WORKSPACE_PORT=8080
WORKSPACE_DOCS_DIR=/app/workspace-docs
WORKSPACE_DEBUG=false

# GitHub Sync Configuration
WORKSPACE_ENABLE_GITHUB_SYNC=false


# Optional: Custom settings
WORKSPACE_GITHUB_BRANCH=main
WORKSPACE_GITHUB_USERNAME=your-username
WORKSPACE_GITHUB_EMAIL=your-email@example.com
