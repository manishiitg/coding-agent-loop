{
  "mcpServers": {
    "pdf-reader": {
      "command": "npx",
      "args": ["@sylphx/pdf-reader-mcp"]
    },
    "gen-pdf": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://gen-pdf.com/mcp"]
    },
    "notion": {
      "command": "",
      "args": null,
      "url": "https://server.smithery.ai/@smithery/notion"
    },
    "excel": {
      "command": "npx",
      "args": ["--yes", "@negokaz/excel-mcp-server"],
      "env": { "EXCEL_MCP_PAGING_CELLS_LIMIT": "4000" }
    },
    "google-docs-mcp": {
      "command": "",
      "args": null,
      "url": "https://server.smithery.ai/googledocs"
    },
    "google-sheets-mcp": {
      "command": "",
      "args": null,
      "url": "https://server.smithery.ai/googlesheets"
    },
    "clickhouse": {
      "command": "uv",
      "args": [
        "run",
        "--with",
        "mcp-clickhouse",
        "--python",
        "3.13",
        "mcp-clickhouse"
      ],
      "env": {
        "CLICKHOUSE_MCP_PAGING_CELLS_LIMIT": "4000",
        "CLICKHOUSE_HOST": "100.64.3.112",
        "CLICKHOUSE_PORT": "8123",
        "CLICKHOUSE_USER": "cm_read",
        "CLICKHOUSE_PASSWORD": "aP$7kZ!rN9eLm#2",
        "CLICKHOUSE_SECURE": "false",
        "CLICKHOUSE_SEND_RECEIVE_TIMEOUT": "300"
      }
    }
  }
}
