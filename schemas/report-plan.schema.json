            "text",
            "markdown",
            "chart",
            "table",
            "cards",
            "stat",
            "alert",
            "pivot"
          ]
        },
        "source": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "filter": {
          "type": "string"
        },
        "query": {
          "type": "string"
        },
        "title": {
          "type": "string"
