# Build stage — same Go binary as workspace-api
FROM golang:1.24 AS builder

RUN apt-get update && apt-get install -y --no-install-recommends ripgrep gcc git && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

ENV CGO_ENABLED=1
RUN go build -o planner .

# Light runtime — NO Chromium, NO Camoufox, NO Python, NO agent-browser
# Only Node.js + git for code-prototype operations (~300MB vs ~1GB+)
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ripgrep git patch util-linux jq \
    build-essential curl wget bash ca-certificates \
    && curl -fsSL https://deb.nodesource.com/setup_24.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=builder /app/planner .

# Create projects directory structure (no Chats/Plans/Downloads)
RUN mkdir -p /app/workspace-projects

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:8080/health || exit 1

CMD ["./planner", "server", "--port", "8080", "--docs-dir", "/app/workspace-projects"]
