# =============================================================================
# Workspace API image - uses same shared base as agent (Dockerfile.base).
# Build context: directory containing workspace/ (e.g. coding-agent-loop).
# =============================================================================
# ARG before first FROM so it is available to the FROM that uses it
ARG BASE_IMAGE

# Build planner binary (glibc for Debian base)
FROM golang:1.24-bookworm AS builder
RUN apt-get update && apt-get install -y --no-install-recommends git gcc libc6-dev && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY workspace/go.mod workspace/go.sum ./
RUN go mod download
COPY workspace/ .

ENV CGO_ENABLED=1
RUN go build -o planner .

# Copy binary into shared base (BASE_IMAGE declared at top)
FROM ${BASE_IMAGE}

WORKDIR /app
COPY --from=builder /app/planner .

RUN mkdir -p /app/workspace-docs /app/data \
  /app/workspace-docs/Downloads /app/workspace-docs/Chats /app/workspace-docs/Workspace

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:8080/health || exit 1

CMD ["./planner", "server", "--port", "8080", "--docs-dir", "/app/workspace-docs"]
