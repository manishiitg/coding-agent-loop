{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--output-dir",
        "../workspace-docs/Downloads",
        "--isolated"
      ],
      "working_dir": "../workspace-docs/Downloads"
    },
    "camofox": {
      "command": "camofox-mcp",
      "args": [],
      "env": {
        "CAMOFOX_URL": "http://localhost:9377"
      }
    }
  }
}
