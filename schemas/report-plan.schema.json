          "items": {
            "$ref": "#/$defs/reportPlanDocumentWidget"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "widgets"
      ]
    },
    "reportPlanDocumentSection": {
