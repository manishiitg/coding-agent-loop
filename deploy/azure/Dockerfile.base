# =============================================================================
# Shared base image for agent and workspace (Debian, glibc).
# Build rarely; push to ACR once. Agent and workspace images FROM this base
# so only app layers (binary, configs) are pushed on each deploy.
# Build: docker build -f deploy/azure/Dockerfile.base -t <acr>.azurecr.io/mcp-agent-base:latest .
# =============================================================================
FROM debian:bookworm-slim

# Common runtime: curl/wget/bash, jq/ripgrep, Python+uv, docker-ce-cli, Node, Chromium, agent-browser.
# Used by both agent (MCPs, code execution) and workspace (scripts, agent-browser, Python).
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    wget \
    bash \
    tmux \
    jq \
    ripgrep \
    python3 \
    python3-pip \
    python3-venv \
    gettext-base \
    gnupg \
    git \
    patch \
    && curl -fsSL https://download.docker.com/linux/debian/gpg | gpg --dearmor -o /usr/share/keyrings/docker-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] https://download.docker.com/linux/debian bookworm stable" > /etc/apt/sources.list.d/docker.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends docker-ce-cli \
    && curl -fsSL https://deb.nodesource.com/setup_24.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && apt-get install -y --no-install-recommends chromium \
    && apt-get install -y --no-install-recommends gcc libc6-dev \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g agent-browser
ENV PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium
ENV AGENT_BROWSER_EXECUTABLE_PATH=/usr/bin/chromium

RUN pip3 install --break-system-packages uv

RUN which npx && which docker && which rg && which jq && which tmux

RUN groupadd -g 1001 appgroup && useradd -m -u 1001 -g appgroup appuser

WORKDIR /app
