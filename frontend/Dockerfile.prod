# Production frontend: build once, serve static files (no hot reload)
# Stage 1: Build
FROM node:20-alpine AS builder

WORKDIR /app

# Build-time env for Vite (baked into bundle)
ARG VITE_API_BASE_URL=http://localhost:8000
ARG VITE_WORKSPACE_API_URL=http://localhost:8081
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_WORKSPACE_API_URL=$VITE_WORKSPACE_API_URL

# Install all deps (including devDependencies for tsc, vite)
COPY package*.json ./
RUN npm ci

COPY . .
# Build with production env so Vite optimizes output
ENV NODE_ENV=production
RUN npm run build

# Stage 2: Serve with nginx
FROM nginx:alpine

# Copy built assets from builder
COPY --from=builder /app/dist /usr/share/nginx/html

# Overwrite runtime-config.js with an empty config. The committed file in
# frontend/public/ holds dev/desktop ports (e.g. http://127.0.0.1:18001) so the
# Electron app can find its locally-spawned Go servers. In the web prod build
# those localhost URLs would (a) not work, (b) trigger Chrome's Local Network
# Access permission prompt for analytics-agent.citymall.live. With an empty
# runtime config, getApiBaseUrl() in src/services/api.ts falls through to the
# VITE_API_BASE_URL build arg (the real prod URL).
RUN printf 'window.__APP_RUNTIME_CONFIG__ = {};\n' > /usr/share/nginx/html/runtime-config.js

# Enable gzip and SPA fallback with cache headers for static assets
RUN echo 'gzip on; \
gzip_types text/plain text/css application/json application/javascript text/xml application/xml text/javascript image/svg+xml; \
gzip_min_length 256; \
gzip_vary on; \
\
server { \
    listen 80; \
    root /usr/share/nginx/html; \
    index index.html; \
    location / { \
        try_files $uri $uri/ /index.html; \
    } \
    location = /index.html { \
        add_header Cache-Control "no-cache, no-store, must-revalidate"; \
    } \
    location /assets/ { \
        expires 1y; \
        add_header Cache-Control "public, immutable"; \
    } \
    location /health { \
        access_log off; \
        default_type application/json; \
        return 200 "{\"status\":\"healthy\",\"service\":\"frontend\"}"; \
    } \
}' > /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
