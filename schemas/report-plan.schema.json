{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "reportPlanDocumentDefaultSort": {
      "properties": {
        "field": {
          "type": "string"
        },
        "direction": {
          "type": "string",
          "enum": [
            "asc",
            "desc"
          ]
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "reportPlanDocumentEntry": {
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "single",
            "row"
          ]
        },
        "widget": {
          "$ref": "#/$defs/reportPlanDocumentWidget"
        },
        "row": {
          "$ref": "#/$defs/reportPlanDocumentRow"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "kind"
      ]
    },
    "reportPlanDocumentRow": {
      "properties": {
