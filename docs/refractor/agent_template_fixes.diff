+		config,
+		logger,
+		tracer,
+		agents.TodoPlannerAnonymizationAgentType,
+		eventBridge,
+	)
+
+	return &HumanControlledTodoPlannerAnonymizationAgent{
+		BaseOrchestratorAgent: baseAgent,
+		baseOrchestrator:      baseOrchestrator,
+	}
+}
